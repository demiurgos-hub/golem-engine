{
  "name": "golem-engine",
  "version": "0.2.0",
  "description": "JavaScript/TypeScript client runtime for Golem Engine: GameClient, protobuf codec, and helpers",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc",
    "prepack": "npm run build",
    "test": "npm run build && node --test"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
